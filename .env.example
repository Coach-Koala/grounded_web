# Lead form target — the hippo-health endpoint (forge task t_807942b3).
# The form fails loud (visible error + mailto fallback) if this is unreachable.
NEXT_PUBLIC_LEADS_ENDPOINT=https://demo.getgroundedhealth.com/api/leads

# Fallback contact mailbox shown when the form errors.
NEXT_PUBLIC_CONTACT_EMAIL=hello@getgroundedhealth.com

# The authenticated app ("Log in" links in header/footer).
NEXT_PUBLIC_APP_URL=https://demo.getgroundedhealth.com

# Set to enable Plausible analytics (leave unset to ship no analytics script).
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=getgroundedhealth.com

# Scorecard app embedded by /scorecard/ during the Phase 1 bridge. The cutover
# target is the temporary 5500 host at scorecard.getgroundedhealth.com so apex
# and www can move to grounded_web without iframe recursion. Set to
# http://localhost:3100 only when developing the 5500 scorecard backend locally.
NEXT_PUBLIC_SCORECARD_APP_URL=https://scorecard.getgroundedhealth.com

# Optional base path for static preview hosts such as GitHub Pages. Leave empty
# for Vercel/custom-domain deployments. CI may override this.
# BASE_PATH=
