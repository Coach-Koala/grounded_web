# Lead form target — the hippo-health endpoint (forge task t_807942b3).
# The form fails loud (visible error + mailto fallback) if this is unreachable.
NEXT_PUBLIC_LEADS_ENDPOINT=https://demo.getgroundedhealth.com/api/leads

# Fallback contact mailbox shown when the form errors.
NEXT_PUBLIC_CONTACT_EMAIL=hello@getgroundedhealth.com

# Set to enable Plausible analytics (leave unset to ship no analytics script).
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=getgroundedhealth.com

# "/grounded_web" while served at coach-koala.github.io/grounded_web,
# "" once the custom domain is live. Set by CI.
# BASE_PATH=
